/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Config file for defining DSL2 per module options and publishing paths
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Available keys to override module options:
        ext.args   = Additional arguments appended to command in module.
        ext.args2  = Second set of arguments appended to command in module (multi-tool modules).
        ext.args3  = Third set of arguments appended to command in module (multi-tool modules).
        ext.prefix = File name prefix for output files.
----------------------------------------------------------------------------------------
*/

process {

    // ── QC modules ────────────────────────────────────────────────────────────

    withName: FASTQC {
        ext.args   = '--quiet'
        publishDir = [
            path: { "${params.outdir}/qc/${meta.id}/fastqc" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: NANOPLOT {
        publishDir = [
            path: { "${params.outdir}/qc/${meta.id}/nanoplot" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'MULTIQC' {
        ext.args   = { params.multiqc_title ? "--title \"$params.multiqc_title\"" : '' }
        publishDir = [
            path: { "${params.outdir}/multiqc" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // ── Genome preparation ────────────────────────────────────────────────────

    withName: PREPARE_GENOME {
        publishDir = [
            enabled: false
        ]
    }

    // ── Tool raw outputs ──────────────────────────────────────────────────────

    withName: ISOCIRC {
        publishDir = [
            [
                path: { "${params.outdir}/circrna/${meta.id}/isocirc" },
                mode: params.publish_dir_mode,
                saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
            ],
            [
                path: { "${params.outdir}/circrna/${meta.id}/bed12" },
                mode: params.publish_dir_mode,
                pattern: "**/*.bed"
            ]
        ]
    }

    withName: CIRCFL_SEQ {
        publishDir = [
            [
                path: { "${params.outdir}/circrna/${meta.id}/circfl_seq" },
                mode: params.publish_dir_mode,
                saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
            ],
            [
                path: { "${params.outdir}/circrna/${meta.id}/bed12" },
                mode: params.publish_dir_mode,
                pattern: "**/circFL_final.bed"
            ]
        ]
    }

    withName: CIRI_LONG {
        publishDir = [
            path: { "${params.outdir}/circrna/${meta.id}/ciri_long" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: CIRCNICK_LRS {
        publishDir = [
            path: { "${params.outdir}/circrna/${meta.id}/circnick_lrs" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: CIRCNICK_LIFTOVER {
        publishDir = [
            path: { "${params.outdir}/circrna/${meta.id}/circnick_lrs/lifted" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // ── BED12 conversions ─────────────────────────────────────────────────────

    withName: CIRILONG_TO_BED12 {
        publishDir = [
            path: { "${params.outdir}/circrna/${meta.id}/bed12" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: CIRCNICK_TO_BED12 {
        publishDir = [
            path: { "${params.outdir}/circrna/${meta.id}/bed12" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // ── Merged outputs ────────────────────────────────────────────────────────

    withName: CIRCRNA_BEDTOOLS_PAIRS {
        publishDir = [
            path: { "${params.outdir}/circrna/${meta.id}/merged/pairs" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: CIRCRNA_MERGE {
        publishDir = [
            [
                path: { "${params.outdir}/circrna/${meta.id}/merged/strict" },
                mode: params.publish_dir_mode,
                pattern: "*strict*",
                saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
            ],
            [
                path: { "${params.outdir}/circrna/${meta.id}/merged/relaxed" },
                mode: params.publish_dir_mode,
                pattern: "*relaxed*",
                saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
            ]
        ]
    }

    withName: CIRCRNA_EXON_MERGE {
        publishDir = [
            path: { "${params.outdir}/circrna/${meta.id}/merged/exon_based" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

}
